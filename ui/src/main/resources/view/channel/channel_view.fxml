<?import io.xeres.ui.controller.common.GxsGroupTreeTableView?>
<?import io.xeres.ui.custom.asyncimage.AsyncImageView?>
<?import io.xeres.ui.custom.ProgressPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.TextFlow?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox alignment="CENTER" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="io.xeres.ui.controller.channel.ChannelViewController">
    <SplitPane fx:id="splitPaneVertical" dividerPositions="0.1" VBox.vgrow="ALWAYS">
        <VBox SplitPane.resizableWithParent="false" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_RIGHT" minHeight="-Infinity" VBox.vgrow="NEVER">
                <VBox.margin>
                    <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                </VBox.margin>
                <Button fx:id="createChannel">
                    <graphic>
                        <FontIcon iconLiteral="mdi2f-folder-plus"/>
                    </graphic>
                    <tooltip>
                        <Tooltip showDuration="1m" maxWidth="300" wrapText="true" text="%channel.view.create.tip"/>
                    </tooltip>
                </Button>
            </HBox>
            <GxsGroupTreeTableView fx:id="channelTree" VBox.vgrow="ALWAYS"/>
        </VBox>
        <VBox VBox.vgrow="ALWAYS">
            <HBox>
                <VBox.margin>
                    <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                </VBox.margin>
                <Button fx:id="newPost" disable="true">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-pencil-plus"/>
                    </graphic>
                    <tooltip>
                        <Tooltip showDuration="1m" maxWidth="300" wrapText="true" text="%forum.view.new-message.tip"/>
                    </tooltip>
                </Button>
            </HBox>
            <SplitPane fx:id="splitPaneHorizontal" dividerPositions="0.3" orientation="VERTICAL" VBox.vgrow="ALWAYS">
                <StackPane styleClass="panel-border">
                    <ProgressPane fx:id="channelMessagesProgress"/>
                </StackPane>
                <ScrollPane fx:id="messagePane" styleClass="message-pane" fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox spacing="12.0" styleClass="message-content">
                        <HBox spacing="12.0">
                            <AsyncImageView fx:id="imageHeader" preserveRatio="true"/>
                            <TextFlow fx:id="messageHeader"/>
                        </HBox>
                        <TextFlow fx:id="messageContent" tabSize="4"/>
                    </VBox>
                </ScrollPane>
            </SplitPane>
        </VBox>
    </SplitPane>
</VBox>