<?import atlantafx.base.controls.CustomTextField?>
<?import atlantafx.base.controls.Spacer?>
<?import io.xeres.ui.custom.asyncimage.AsyncImageView?>
<?import io.xeres.ui.custom.ImageSelectorView?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import org.kordamp.ikonli.javafx.*?>
<VBox alignment="CENTER" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="io.xeres.ui.controller.contact.ContactViewController">
    <SplitPane dividerPositions="0.3" VBox.vgrow="ALWAYS">
        <VBox SplitPane.resizableWithParent="false" VBox.vgrow="NEVER">
            <HBox fx:id="ownContactGroup" styleClass="group-emphasis, group-frame" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="8.0" bottom="8.0" left="8.0"/>
                </padding>
                <StackPane alignment="TOP_LEFT">
                    <HBox.margin>
                        <Insets right="8.0"/>
                    </HBox.margin>
                    <Circle fx:id="ownContactCircle" radius="24" StackPane.alignment="CENTER_LEFT" visible="false"/>
                    <AsyncImageView fx:id="ownContactImageView" fitWidth="48" fitHeight="48" visible="false"/>
                    <Circle fx:id="ownContactState" radius="8" StackPane.alignment="BOTTOM_RIGHT" fill="lawngreen"/>
                </StackPane>
                <Label fx:id="ownContactName" styleClass="title-4"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" minHeight="-Infinity" VBox.vgrow="NEVER">
                <VBox.margin>
                    <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                </VBox.margin>
                <CustomTextField fx:id="searchTextField" promptText="%contact-view.search.prompt" HBox.hgrow="ALWAYS"/>
                <MenuButton styleClass="no-arrow, flat">
                    <graphic>
                        <FontIcon iconLiteral="mdi2f-filter-menu"/>
                    </graphic>
                    <items>
                        <CheckMenuItem fx:id="showAllContacts" text="%contact-view.search.show-all" selected="true"/>
                    </items>
                </MenuButton>
            </HBox>
            <TreeTableView fx:id="contactTreeTableView" minWidth="-Infinity" prefWidth="200" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="%contact-view.search.no-contacts"/>
                </placeholder>
                <columns>
                    <TreeTableColumn fx:id="contactTreeTableNameColumn" prefWidth="180.0" text="%name"/>
                    <TreeTableColumn fx:id="contactTreeTablePresenceColumn" prefWidth="40.0"/>
                </columns>
            </TreeTableView>
        </VBox>
        <VBox>
            <padding>
                <Insets right="4.0" top="4.0"/>
            </padding>
            <HBox fx:id="detailsHeader" visible="false">
                <VBox.margin>
                    <Insets bottom="4.0" left="8.0" right="4.0" top="4.0"/>
                </VBox.margin>
                <VBox>
                    <ImageSelectorView fx:id="contactImageSelectorView" fitWidth="128.0" fitHeight="128.0"/>
                    <HBox fx:id="rating" visible="false" alignment="CENTER">
                        <VBox.margin>
                            <Insets top="2.0" left="12.0" right="12.0"/>
                        </VBox.margin>
                        <Button styleClass="flat, button-icon, success" disable="true">
                            <graphic>
                                <FontIcon iconLiteral="mdi2t-thumb-up"/>
                            </graphic>
                        </Button>
                        <Label fx:id="likeLabel" text="0" minWidth="20.0"/>
                        <Spacer/>
                        <Button styleClass="flat, button-icon, danger" disable="true">
                            <graphic>
                                <FontIcon iconLiteral="mdi2t-thumb-down"/>
                            </graphic>
                        </Button>
                        <Label fx:id="dislikeLabel" text="0" minWidth="20.0"/>
                    </HBox>
                </VBox>
                <HBox HBox.hgrow="ALWAYS">
                    <HBox.margin>
                        <Insets left="8.0"/>
                    </HBox.margin>
                    <VBox>
                        <Label fx:id="nameLabel" style="-fx-font-size: 2.5em"/>
                        <FlowPane orientation="VERTICAL" maxHeight="80">
                            <Label fx:id="badgeOwn" text="%contact-view.badge.own" styleClass="accent" managed="false" visible="false">
                                <FlowPane.margin>
                                    <Insets right="12.0"/>
                                </FlowPane.margin>
                                <graphic>
                                    <FontIcon iconLiteral="mdi2l-label"/>
                                </graphic>
                                <tooltip>
                                    <Tooltip showDuration="1m" maxWidth="300" wrapText="true" text="%contact-view.badge.own.tip"/>
                                </tooltip>
                            </Label>
                            <Label fx:id="badgePartial" text="%contact-view.badge.partial" styleClass="warning" managed="false" visible="false">
                                <FlowPane.margin>
                                    <Insets right="12.0"/>
                                </FlowPane.margin>
                                <graphic>
                                    <FontIcon iconLiteral="mdi2l-label"/>
                                </graphic>
                                <tooltip>
                                    <Tooltip showDuration="1m" maxWidth="300" wrapText="true" text="%contact-view.badge.partial.tip"/>
                                </tooltip>
                            </Label>
                            <Label fx:id="badgeAccepted" text="%contact-view.badge.accepted" managed="false" visible="false">
                                <FlowPane.margin>
                                    <Insets right="12.0"/>
                                </FlowPane.margin>
                                <graphic>
                                    <FontIcon iconLiteral="mdi2l-label"/>
                                </graphic>
                                <tooltip>
                                    <Tooltip showDuration="1m" maxWidth="300" wrapText="true" text="%contact-view.badge.accepted.tip"/>
                                </tooltip>
                            </Label>
                            <Label fx:id="badgeUnvalidated" text="%contact-view.badge.not-validated" styleClass="warning" managed="false" visible="false">
                                <FlowPane.margin>
                                    <Insets right="12.0"/>
                                </FlowPane.margin>
                                <graphic>
                                    <FontIcon iconLiteral="mdi2l-label"/>
                                </graphic>
                                <tooltip>
                                    <Tooltip showDuration="1m" maxWidth="300" wrapText="true"
                                             text="%contact-view.badge.not-validated.tip"/>
                                </tooltip>
                            </Label>
                            <Label fx:id="badgeBanned" text="%contact-view.badge.banned" styleClass="danger" managed="false" visible="false">
                                <FlowPane.margin>
                                    <Insets right="12.0"/>
                                </FlowPane.margin>
                                <graphic>
                                    <FontIcon iconLiteral="mdi2l-label"/>
                                </graphic>
                                <tooltip>
                                    <Tooltip showDuration="1m" maxWidth="300" wrapText="true"
                                             text="%contact-view.badge.banned.tip"/>
                                </tooltip>
                            </Label>
                            <Label fx:id="badgeRestricted" text="%contact-view.badge.restricted" styleClass="warning" managed="false" visible="false">
                                <FlowPane.margin>
                                    <Insets right="12.0"/>
                                </FlowPane.margin>
                                <graphic>
                                    <FontIcon iconLiteral="mdi2l-label"/>
                                </graphic>
                                <tooltip>
                                    <Tooltip showDuration="1m" maxWidth="300" wrapText="true"
                                             text="%contact-view.badge.restricted.tip"/>
                                </tooltip>
                            </Label>
                        </FlowPane>
                    </VBox>
                    <Spacer HBox.hgrow="ALWAYS"/>
                    <VBox>
                        <Button fx:id="chatButton" disable="true">
                            <graphic>
                                <FontIcon iconLiteral="mdi2m-message"/>
                            </graphic>
                        </Button>
                    </VBox>
                </HBox>
            </HBox>
            <VBox fx:id="detailsView" visible="false" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets right="4.0" top="4.0" left="12.0" bottom="4.0"/>
                </padding>
                <GridPane>
                    <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="100.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="280.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <Label fx:id="typeLabel"/>
                    <Label fx:id="typeDescription" GridPane.columnIndex="1"/>
                    <Label fx:id="createdOrUpdated" text="%contact-view.information.created" GridPane.rowIndex="1"/>
                    <Label fx:id="createdLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>
                <GridPane fx:id="trustGrid" managed="false" visible="false">
                    <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="100.0"/>
                        <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="180.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <Label text="%trust"/>
                    <ChoiceBox fx:id="trust" GridPane.columnIndex="1" minWidth="160.0">
                        <tooltip>
                            <Tooltip showDuration="1m" maxWidth="300" wrapText="true" text="%rs-id.add.trust.tip"/>
                        </tooltip>
                    </ChoiceBox>
                </GridPane>
                <GridPane fx:id="opinionGrid" managed="false" visible="false">
                    <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="100.0"/>
                        <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="180.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <Label text="%contact-view.opinion"/>
                    <ComboBox fx:id="opinion" GridPane.columnIndex="1" minWidth="160.0">
                        <tooltip>
                            <Tooltip showDuration="1m" maxWidth="300" wrapText="true" text="%contact-view.opinion.tip"/>
                        </tooltip>
                    </ComboBox>
                    <CheckBox fx:id="banProfileCheckBox" text="%contact-view.auto-ban" GridPane.columnIndex="2" managed="false" visible="false">
                        <tooltip>
                            <Tooltip showDuration="1m" maxWidth="300" wrapText="true" text="%contact-view.auto-ban.tip"/>
                        </tooltip>
                    </CheckBox>
                </GridPane>
                <VBox fx:id="locationsView" visible="false" managed="false">
                    <VBox.margin>
                        <Insets top="16.0"/>
                    </VBox.margin>
                    <Label text="%contact-view.information.locations" styleClass="title-4"/>
                    <TableView fx:id="locationTableView" prefHeight="130.0">
                        <VBox.margin>
                            <Insets top="8.0"/>
                        </VBox.margin>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="locationTableNameColumn" text="%name"/>
                            <TableColumn fx:id="locationTablePresenceColumn" minWidth="35.0" prefWidth="35.0" maxWidth="35.0"/>
                            <TableColumn fx:id="locationTableIPColumn" minWidth="120.0" prefWidth="120.0" maxWidth="460.0" text="%ip"/><!-- hidden addresses can be long -->
                            <TableColumn fx:id="locationTablePortColumn" minWidth="60.0" prefWidth="60.0" maxWidth="60.0" text="%port"/>
                            <TableColumn fx:id="locationTableLastConnectedColumn" minWidth="100.0" prefWidth="140.0" maxWidth="140.0" text="%contact-view.column.last-connected"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </VBox>
    </SplitPane>
</VBox>