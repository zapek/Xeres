<?import io.xeres.ui.custom.asyncimage.AsyncImageView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.TextFlow?>
<fx:root type="ScrollPane" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" styleClass="message-pane" fitToWidth="true">
    <VBox spacing="12.0" styleClass="message-content">
        <HBox spacing="12.0">
            <AsyncImageView fx:id="image" preserveRatio="true"/>
            <TextFlow fx:id="header"/>
        </HBox>
        <TextFlow fx:id="body" tabSize="4"/>
    </VBox>
</fx:root>
