<?import atlantafx.base.controls.CustomTextField?>
<?import atlantafx.base.controls.Spacer?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import org.kordamp.ikonli.javafx.*?>
<VBox
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="io.xeres.ui.controller.xweb.VoyagerWindowController"
        minWidth="320.0"
        minHeight="260.0"
        prefHeight="800.0" prefWidth="800.0"
        alignment="CENTER">

    <ToolBar VBox.vgrow="NEVER" styleClass="tool-bar-flat">
        <!-- toolbar + URL bar -->
        <VBox.margin>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0"/>
        </VBox.margin>
        <Button fx:id="backButton" disable="true">
            <graphic>
                <FontIcon iconLiteral="mdi2c-chevron-left"/>
            </graphic>
        </Button>

        <Button fx:id="forwardButton" disable="true">
            <graphic>
                <FontIcon iconLiteral="mdi2c-chevron-right"/>
            </graphic>
        </Button>

        <Button fx:id="refreshButton">
            <graphic>
                <FontIcon iconLiteral="mdi2r-refresh"/>
            </graphic>
        </Button>

        <Spacer HBox.hgrow="SOMETIMES" maxWidth="200"/>

        <Button>
            <graphic>
                <FontIcon iconLiteral="mdi2b-bookmark-outline"/>
            </graphic>
        </Button>

        <CustomTextField fx:id="urlField" HBox.hgrow="SOMETIMES">
            <left>
                <FontIcon iconLiteral="mdi2l-lock"/>
            </left>
        </CustomTextField>
    </ToolBar>

    <WebView fx:id="webView" VBox.vgrow="ALWAYS"/>

</VBox>
